<svg width="192" height="192" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="192" height="192" fill="#10b981" rx="40"/>
  
  <!-- Leaf Icon -->
  <g transform="translate(96, 96)">
    <!-- Stem -->
    <rect x="-3" y="20" width="6" height="40" fill="#ffffff" rx="3"/>
    
    <!-- Left Leaf -->
    <ellipse cx="-25" cy="0" rx="30" ry="45" fill="#ffffff" transform="rotate(-30 -25 0)"/>
    
    <!-- Right Leaf -->
    <ellipse cx="25" cy="0" rx="30" ry="45" fill="#ffffff" transform="rotate(30 25 0)"/>
    
    <!-- Center Leaf -->
    <ellipse cx="0" cy="-15" rx="25" ry="50" fill="#ffffff"/>
  </g>
</svg>
