<svg width="512" height="512" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="512" height="512" fill="#10b981" rx="100"/>
  
  <!-- Leaf Icon (scaled up) -->
  <g transform="translate(256, 256)">
    <!-- Stem -->
    <rect x="-8" y="50" width="16" height="110" fill="#ffffff" rx="8"/>
    
    <!-- Left Leaf -->
    <ellipse cx="-70" cy="0" rx="80" ry="120" fill="#ffffff" transform="rotate(-30 -70 0)"/>
    
    <!-- Right Leaf -->
    <ellipse cx="70" cy="0" rx="80" ry="120" fill="#ffffff" transform="rotate(30 70 0)"/>
    
    <!-- Center Leaf -->
    <ellipse cx="0" cy="-40" rx="65" ry="130" fill="#ffffff"/>
  </g>
</svg>
